#!/bin/bash

# BMAD Quick Setup
# One command to create a project, install BMAD, and open Claude.
# Usage: bmad <project-name>

VERSION="1.0.0"

if [ "$1" = "--version" ] || [ "$1" = "-v" ]; then
  echo "bmad-quick-setup $VERSION"
  exit 0
fi

if [ "$1" = "--help" ] || [ "$1" = "-h" ]; then
  echo "Usage: bmad <project-name>"
  echo ""
  echo "Creates a project folder, installs BMAD with sensible defaults,"
  echo "and opens Claude Code ready to go."
  echo ""
  echo "Options:"
  echo "  -v, --version    Show version"
  echo "  -h, --help       Show this help"
  echo ""
  echo "Prerequisites: Node.js, Claude Code CLI"
  exit 0
fi

PROJECT_NAME="$1"

if [ -z "$PROJECT_NAME" ]; then
  echo "What do you want to call your project?"
  read -r PROJECT_NAME
fi

if [ -z "$PROJECT_NAME" ]; then
  echo "No project name provided. Exiting."
  exit 1
fi

# Get first name from macOS username (before the dot), capitalize it
USER_FIRST_NAME="$(whoami | cut -d. -f1 | sed 's/^./\U&/')"

echo ""
echo "==================================="
echo "  BMAD Quick Setup"
echo "==================================="
echo "  Project:  $PROJECT_NAME"
echo "  User:     $USER_FIRST_NAME"
echo "==================================="
echo ""

# Check prerequisites
if ! command -v node &> /dev/null; then
  echo "Error: Node.js is not installed."
  echo "Install it with: brew install node"
  exit 1
fi

if ! command -v claude &> /dev/null; then
  echo "Error: Claude Code CLI is not installed."
  echo "Install it with: npm install -g @anthropic-ai/claude-code"
  exit 1
fi

# Create and enter the project directory
mkdir -p "$PROJECT_NAME"
cd "$PROJECT_NAME" || exit 1

echo "Installing BMAD..."
echo ""

# Install BMAD with all defaults
npx bmad-method install \
  --directory "." \
  --modules "bmm" \
  --tools "claude-code" \
  --user-name "$USER_FIRST_NAME" \
  --communication-language "English" \
  --document-output-language "English" \
  --output-folder "_bmad-output" \
  -y

echo ""
echo "BMAD installed. Opening Claude..."
echo ""

# Open Claude in the project directory
claude
