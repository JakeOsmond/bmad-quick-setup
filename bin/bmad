#!/bin/bash

# BMAD Quick Setup
# One command to create a project, install BMAD, and open Claude.
# Usage: bmad <project-name>

VERSION="1.2.0"

if [ "$1" = "--version" ] || [ "$1" = "-v" ]; then
  echo "bmad-quick-setup $VERSION"
  exit 0
fi

if [ "$1" = "--help" ] || [ "$1" = "-h" ]; then
  echo "Usage: bmad <project-name>"
  echo ""
  echo "Creates a project folder, installs BMAD with sensible defaults,"
  echo "and opens Claude Code ready to go."
  echo ""
  echo "Options:"
  echo "  -v, --version    Show version"
  echo "  -h, --help       Show this help"
  echo ""
  echo "Prerequisites: Node.js, Claude Code CLI"
  exit 0
fi

PROJECT_NAME="$1"

if [ -z "$PROJECT_NAME" ]; then
  echo "What do you want to call your project?"
  read -r PROJECT_NAME
fi

if [ -z "$PROJECT_NAME" ]; then
  echo "No project name provided. Exiting."
  exit 1
fi

# Get first name from macOS username (before the dot), capitalize it
USER_FIRST_NAME="$(whoami | cut -d. -f1 | sed 's/^./\U&/')"

echo ""
echo "==================================="
echo "  BMAD Quick Setup"
echo "==================================="
echo "  Project:  $PROJECT_NAME"
echo "  User:     $USER_FIRST_NAME"
echo "==================================="
echo ""

# Check prerequisites
if ! command -v node &> /dev/null; then
  echo "Error: Node.js is not installed."
  echo "Install it with: brew install node"
  exit 1
fi

# Choose AI coding tool
echo "Which AI coding tool do you want to use?"
echo ""
echo "  1) Claude Code"
echo "  2) Codex (OpenAI)"
echo ""
printf "Enter choice [1]: "
read -r TOOL_CHOICE

case "$TOOL_CHOICE" in
  2)
    TOOL_ID="codex"
    TOOL_CMD="codex"
    TOOL_INSTALL="npm install -g @openai/codex"
    ;;
  *)
    TOOL_ID="claude-code"
    TOOL_CMD="claude"
    TOOL_INSTALL="npm install -g @anthropic-ai/claude-code"
    ;;
esac

if ! command -v "$TOOL_CMD" &> /dev/null; then
  echo "Error: $TOOL_CMD is not installed."
  echo "Install it with: $TOOL_INSTALL"
  exit 1
fi

# Create and enter the project directory
mkdir -p "$PROJECT_NAME"
cd "$PROJECT_NAME" || exit 1

echo ""
echo "Installing BMAD with $TOOL_ID..."
echo ""

# Install BMAD with selected tool
npx bmad-method install \
  --directory "." \
  --modules "bmm" \
  --tools "$TOOL_ID" \
  --user-name "$USER_FIRST_NAME" \
  --communication-language "English" \
  --document-output-language "English" \
  --output-folder "_bmad-output" \
  -y

echo ""
echo "BMAD installed. Opening $TOOL_CMD with Party Mode..."
echo "Note: If $TOOL_CMD asks whether you trust this folder, select Yes."
echo ""

# Open the selected tool and kick off Party Mode automatically
"$TOOL_CMD" "/bmad-party-mode"
